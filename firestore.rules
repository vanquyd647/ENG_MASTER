rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Words collection (Static content - anyone can read, only admin can write)
    match /words/{wordId} {
      allow read: if isSignedIn();
      allow write: if false; // Only manageable via server or console for now
    }

    // User collection
    match /users/{userId} {
      function isValidUser(data) {
        return data.keys().hasAll(['uid', 'email']) &&
               data.keys().hasOnly(['uid', 'email', 'displayName', 'photoURL', 'totalWordsLearned', 'studyTimeMinutes', 'streak', 'dailyGoal', 'lastStudyDate', 'history']) &&
               data.uid == request.auth.uid &&
               data.email is string && data.email.size() < 256 &&
               (!data.keys().hasAny(['displayName']) || (data.displayName is string && data.displayName.size() <= 120)) &&
               (!data.keys().hasAny(['photoURL']) || (data.photoURL is string && data.photoURL.size() <= 900000)) &&
               (!data.keys().hasAny(['totalWordsLearned']) || (data.totalWordsLearned is int && data.totalWordsLearned >= 0)) &&
               (!data.keys().hasAny(['studyTimeMinutes']) || (data.studyTimeMinutes is int && data.studyTimeMinutes >= 0)) &&
               (!data.keys().hasAny(['streak']) || (data.streak is int && data.streak >= 0)) &&
               (!data.keys().hasAny(['dailyGoal']) || (data.dailyGoal is int && data.dailyGoal >= 5 && data.dailyGoal <= 50)) &&
               (!data.keys().hasAny(['lastStudyDate']) || data.lastStudyDate is string) &&
               (!data.keys().hasAny(['history']) || (data.history is list && data.history.size() <= 50));
      }

      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().keys().size() <= 10;
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().uid == existing().uid &&
                    incoming().email == existing().email &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'totalWordsLearned', 'studyTimeMinutes', 'streak', 'dailyGoal', 'lastStudyDate', 'history']);
    }

    // User progress subcollection
    match /users/{userId}/progress/{wordId} {
      function isValidProgress(data) {
        return data.keys().hasAll(['userId', 'wordId', 'easiness', 'interval', 'repetitions', 'nextReviewDate']) &&
               data.keys().hasOnly(['userId', 'wordId', 'easiness', 'interval', 'repetitions', 'nextReviewDate', 'lastReviewDate', 'wrongCount']) &&
               data.userId == request.auth.uid &&
               data.wordId == wordId &&
               data.easiness is number &&
               data.interval is int &&
               data.repetitions is int &&
               data.nextReviewDate is string &&
               (!data.keys().hasAny(['lastReviewDate']) || data.lastReviewDate is string) &&
               (!data.keys().hasAny(['wrongCount']) || (data.wrongCount is int && data.wrongCount >= 0));
      }

      allow list: if isOwner(userId);
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidProgress(incoming());
      allow update: if isOwner(userId) && isValidProgress(incoming());
      allow delete: if isOwner(userId);
    }
  }
}
